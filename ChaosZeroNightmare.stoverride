name: CZN 小开关尝试
desc: 尝试将卡厄斯梦境国服资源 CDN 请求从 .cn 地址改为非 .cn 地址

http:
  mitm:
    - czn.cdn.net.cn
    - '*.czn.cdn.net.cn'

  script:
    - match: ^https?:\/\/czn\.cdn\.net\.cn\/
      name: CZN_CDN_Rewrite
      type: request
    - match: ^https?:\/\/.+\.czn\.cdn\.net\.cn\/
      name: CZN_CDN_Rewrite
      type: request

script-providers:
  CZN_CDN_Rewrite:
    url: https://raw.githubusercontent.com/zfcc2026/stash_config/refs/heads/main/czn-cdn-rewrite.js
    interval: 86400
