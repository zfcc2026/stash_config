name: "blackmatrix7 分流规则覆写"

desc: |-
  适用于“机场原始 Stash 订阅可以直接导入使用”的场景。
  通过 include-all: true 引用原订阅中的全部节点。
  规则使用 blackmatrix7/ios_rule_script 的 Clash 规则集。
  本覆写不会替换原订阅规则，只会把本文件中的规则插入到原规则前面。

mode: rule

proxy-groups:

# ==================================================
# 核心选择组
# ==================================================
  - name: BM7-Proxy
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Global.png
    type: select
    include-all: true
    proxies:
      - DIRECT

  - name: BM7-Auto
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Speedtest.png
    type: url-test
    include-all: true
    interval: 600
    tolerance: 300
    lazy: true
    url: http://www.gstatic.com/generate_204

  - name: BM7-Auto 日美
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Speedtest.png
    type: url-test
    include-all: true
    interval: 600
    tolerance: 300
    lazy: true
    url: http://www.gstatic.com/generate_204
    filter: "(?i)(🇯🇵|JP|Japan|Tokyo|日本|东京|大阪|京日|苏日|沪日|上日|川日|深日|广日|🇺🇸|US|USA|America|United States|美国|凤凰城|洛杉矶|西雅图|芝加哥|纽约|沪美)"

# ==================================================
# 分流策略组：BM7-分流-*
# ==================================================
  - name: BM7-分流-AI
    icon: https://raw.githubusercontent.com/Orz-3/mini/master/Color/OpenAI.png
    type: select
    proxies:
      - BM7-Proxy
      - BM7-Auto
      - BM7-Auto 日美
      - BM7-节点-US 美国
      - BM7-节点-JP 日本
      - BM7-节点-SG 新加坡
      - BM7-节点-HK 香港
      - DIRECT

  - name: BM7-分流-Developer
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/GitHub.png
    type: select
    proxies:
      - BM7-Proxy
      - BM7-Auto
      - BM7-Auto 日美
      - BM7-节点-HK 香港
      - BM7-节点-JP 日本
      - BM7-节点-SG 新加坡
      - BM7-节点-US 美国
      - DIRECT

  - name: BM7-分流-Google
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Google_Search.png
    type: select
    proxies:
      - BM7-Proxy
      - BM7-Auto
      - BM7-Auto 日美
      - BM7-节点-HK 香港
      - BM7-节点-JP 日本
      - BM7-节点-SG 新加坡
      - BM7-节点-TW 台湾省
      - BM7-节点-US 美国
      - DIRECT

  - name: BM7-分流-YouTube
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/YouTube.png
    type: select
    proxies:
      - BM7-Proxy
      - BM7-Auto
      - BM7-Auto 日美
      - BM7-节点-HK 香港
      - BM7-节点-JP 日本
      - BM7-节点-SG 新加坡
      - BM7-节点-TW 台湾省
      - BM7-节点-US 美国
      - DIRECT

  - name: BM7-分流-Telegram
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Telegram.png
    type: select
    proxies:
      - BM7-Proxy
      - BM7-Auto
      - BM7-Auto 日美
      - BM7-节点-SG 新加坡
      - BM7-节点-HK 香港
      - BM7-节点-JP 日本
      - BM7-节点-US 美国
      - DIRECT

  - name: BM7-分流-Social
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Twitter.png
    type: select
    proxies:
      - BM7-Proxy
      - BM7-Auto
      - BM7-Auto 日美
      - BM7-节点-HK 香港
      - BM7-节点-JP 日本
      - BM7-节点-SG 新加坡
      - BM7-节点-TW 台湾省
      - BM7-节点-US 美国
      - DIRECT

  - name: BM7-分流-Streaming
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Netflix.png
    type: select
    proxies:
      - BM7-Proxy
      - BM7-Auto
      - BM7-Auto 日美
      - BM7-节点-JP 日本
      - BM7-节点-US 美国
      - BM7-节点-SG 新加坡
      - BM7-节点-HK 香港
      - BM7-节点-TW 台湾省
      - DIRECT

  - name: BM7-分流-Game
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Game.png
    type: select
    proxies:
      - BM7-Proxy
      - BM7-Auto
      - BM7-Auto 日美
      - BM7-节点-HK 香港
      - BM7-节点-JP 日本
      - BM7-节点-SG 新加坡
      - BM7-节点-TW 台湾省
      - BM7-节点-KR 韩国
      - BM7-节点-US 美国
      - DIRECT

  - name: BM7-分流-Apple
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Apple.png
    type: select
    proxies:
      - BM7-Proxy
      - BM7-Auto
      - BM7-Auto 日美
      - DIRECT
      - BM7-节点-HK 香港
      - BM7-节点-JP 日本
      - BM7-节点-SG 新加坡
      - BM7-节点-US 美国

  - name: BM7-分流-Microsoft
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Microsoft.png
    type: select
    proxies:
      - BM7-Proxy
      - BM7-Auto
      - BM7-Auto 日美
      - DIRECT
      - BM7-节点-HK 香港
      - BM7-节点-JP 日本
      - BM7-节点-SG 新加坡
      - BM7-节点-US 美国

  - name: BM7-分流-PayPal
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/PayPal.png
    type: select
    proxies:
      - BM7-Proxy
      - BM7-Auto 日美
      - DIRECT
      - BM7-节点-HK 香港
      - BM7-节点-TW 台湾省
      - BM7-节点-JP 日本
      - BM7-节点-SG 新加坡
      - BM7-节点-KR 韩国
      - BM7-节点-US 美国

  - name: BM7-分流-Amazon
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Amazon.png
    type: select
    proxies:
      - BM7-Proxy
      - BM7-Auto 日美
      - DIRECT
      - BM7-节点-HK 香港
      - BM7-节点-TW 台湾省
      - BM7-节点-JP 日本
      - BM7-节点-SG 新加坡
      - BM7-节点-KR 韩国
      - BM7-节点-US 美国

# ==================================================
# 节点地区组：BM7-节点-*
# ==================================================
  - name: BM7-节点-HK 香港
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Hong_Kong.png
    type: url-test
    include-all: true
    interval: 600
    tolerance: 300
    lazy: true
    url: http://www.gstatic.com/generate_204
    filter: "(?i)(🇭🇰|HK|Hong|hong|香港|深港|沪港|京港|港)"

  - name: BM7-节点-TW 台湾省
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/China.png
    type: url-test
    include-all: true
    interval: 600
    tolerance: 300
    lazy: true
    url: http://www.gstatic.com/generate_204
    filter: "(?i)(🇹🇼|TW|TWN|Taiwan|Taipei|taiwan|台湾|台灣|台北|台中|新北|彰化)"

  - name: BM7-节点-JP 日本
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Japan.png
    type: url-test
    include-all: true
    interval: 600
    tolerance: 300
    lazy: true
    url: http://www.gstatic.com/generate_204
    filter: "(?i)(🇯🇵|JP|Japan|japan|Tokyo|tokyo|日本|东京|大阪|京日|苏日|沪日|上日|川日|深日|广日|日)"

  - name: BM7-节点-KR 韩国
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Korea.png
    type: url-test
    include-all: true
    interval: 600
    tolerance: 300
    lazy: true
    url: http://www.gstatic.com/generate_204
    filter: "(?i)(🇰🇷|KR|Korea|korea|KOR|韩国|首尔|韩|韓|春川)"

  - name: BM7-节点-US 美国
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/United_States.png
    type: url-test
    include-all: true
    interval: 600
    tolerance: 300
    lazy: true
    url: http://www.gstatic.com/generate_204
    filter: "(?i)(🇺🇸|US|USA|America|america|United States|美国|凤凰城|洛杉矶|西雅图|芝加哥|纽约|沪美|美)"

  - name: BM7-节点-SG 新加坡
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Singapore.png
    type: url-test
    include-all: true
    interval: 600
    tolerance: 300
    lazy: true
    url: http://www.gstatic.com/generate_204
    filter: "(?i)(🇸🇬|SG|Sing|sing|新加坡|狮城|沪新|京新|深新|杭新|广新)"

  - name: BM7-节点-其它地区
    icon: https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Global.png
    type: url-test
    include-all: true
    interval: 600
    tolerance: 300
    lazy: true
    url: http://www.gstatic.com/generate_204
    filter: "(?i)^(?!.*(?:🇭🇰|HK|Hong|hong|香港|深港|沪港|京港|港|🇹🇼|TW|TWN|Taiwan|Taipei|taiwan|台湾|台灣|台北|台中|新北|彰化|🇯🇵|JP|Japan|japan|Tokyo|tokyo|日本|东京|大阪|京日|苏日|沪日|上日|川日|深日|广日|日|🇰🇷|KR|Korea|korea|KOR|韩国|首尔|韩|韓|春川|🇺🇸|US|USA|America|america|United States|美国|凤凰城|洛杉矶|西雅图|芝加哥|纽约|沪美|美|🇸🇬|SG|Sing|sing|新加坡|狮城|沪新|京新|深新|杭新|广新)).*"


rules:

# ==================================================
# 局域网 / 私有地址 / 本机地址直连
# ==================================================
  - DOMAIN,localhost,DIRECT
  - DOMAIN-SUFFIX,localhost,DIRECT
  - DOMAIN-SUFFIX,local,DIRECT
  - DOMAIN-SUFFIX,lan,DIRECT
  - DOMAIN-SUFFIX,home.arpa,DIRECT
  - DOMAIN-SUFFIX,localdomain,DIRECT
  - DOMAIN-SUFFIX,intranet,DIRECT
  - IP-CIDR,0.0.0.0/8,DIRECT,no-resolve
  - IP-CIDR,10.0.0.0/8,DIRECT,no-resolve
  - IP-CIDR,100.64.0.0/10,DIRECT,no-resolve
  - IP-CIDR,127.0.0.0/8,DIRECT,no-resolve
  - IP-CIDR,169.254.0.0/16,DIRECT,no-resolve
  - IP-CIDR,172.16.0.0/12,DIRECT,no-resolve
  - IP-CIDR,192.168.0.0/16,DIRECT,no-resolve
  - IP-CIDR,224.0.0.0/4,DIRECT,no-resolve
  - IP-CIDR,255.255.255.255/32,DIRECT,no-resolve
  - IP-CIDR6,::1/128,DIRECT,no-resolve
  - IP-CIDR6,fc00::/7,DIRECT,no-resolve
  - IP-CIDR6,fe80::/10,DIRECT,no-resolve
  - IP-CIDR6,ff00::/8,DIRECT,no-resolve

# ==================================================
# 办公软件直连补充
# ==================================================
  - DOMAIN-SUFFIX,dingtalk.com,DIRECT
  - DOMAIN-SUFFIX,dingtalkapps.com,DIRECT
  - DOMAIN-SUFFIX,dingtalkcdn.com,DIRECT
  - DOMAIN-SUFFIX,alicdn.com,DIRECT
  - DOMAIN-SUFFIX,aliyuncs.com,DIRECT
  - DOMAIN-SUFFIX,alibaba.com,DIRECT
  - DOMAIN-SUFFIX,wecom.work,DIRECT
  - DOMAIN-SUFFIX,work.weixin.qq.com,DIRECT
  - DOMAIN-SUFFIX,feishu.cn,DIRECT
  - DOMAIN-SUFFIX,feishuapp.cn,DIRECT

# ==================================================
# QUIC 拦截
# ==================================================
  - SCRIPT,bm7_quic,REJECT

# ==================================================
# 广告与隐私
# ==================================================
  - RULE-SET,BM7-Advertising,REJECT
  - RULE-SET,BM7-Privacy,REJECT

# ==================================================
# AI 补充域名
# ==================================================
  - DOMAIN-SUFFIX,cursor.com,BM7-分流-AI
  - DOMAIN-SUFFIX,cursor.sh,BM7-分流-AI
  - DOMAIN-SUFFIX,anysphere.co,BM7-分流-AI
  - DOMAIN-SUFFIX,openrouter.ai,BM7-分流-AI
  - DOMAIN-SUFFIX,perplexity.ai,BM7-分流-AI
  - DOMAIN-SUFFIX,poe.com,BM7-分流-AI
  - DOMAIN-SUFFIX,x.ai,BM7-分流-AI
  - DOMAIN-SUFFIX,grok.com,BM7-分流-AI

# ==================================================
# AI 规则集
# ==================================================
  - RULE-SET,BM7-OpenAI,BM7-分流-AI
  - RULE-SET,BM7-Claude,BM7-分流-AI
  - RULE-SET,BM7-Anthropic,BM7-分流-AI
  - RULE-SET,BM7-Gemini,BM7-分流-AI
  - RULE-SET,BM7-Copilot,BM7-分流-AI

# ==================================================
# 开发相关规则集
# ==================================================
  - RULE-SET,BM7-GitHub,BM7-分流-Developer
  - RULE-SET,BM7-GitLab,BM7-分流-Developer
  - RULE-SET,BM7-Docker,BM7-分流-Developer
  - RULE-SET,BM7-Jetbrains,BM7-分流-Developer
  - RULE-SET,BM7-Npmjs,BM7-分流-Developer
  - RULE-SET,BM7-Python,BM7-分流-Developer

# ==================================================
# Google / YouTube / Telegram
# ==================================================
  - RULE-SET,BM7-YouTube,BM7-分流-YouTube
  - RULE-SET,BM7-Google,BM7-分流-Google
  - RULE-SET,BM7-Telegram,BM7-分流-Telegram

# ==================================================
# 社交媒体
# ==================================================
  - RULE-SET,BM7-Twitter,BM7-分流-Social
  - RULE-SET,BM7-Instagram,BM7-分流-Social
  - RULE-SET,BM7-Facebook,BM7-分流-Social
  - RULE-SET,BM7-Reddit,BM7-分流-Social
  - RULE-SET,BM7-Discord,BM7-分流-Social
  - RULE-SET,BM7-TikTok,BM7-分流-Social
  - RULE-SET,BM7-Threads,BM7-分流-Social
  - RULE-SET,BM7-Whatsapp,BM7-分流-Social
  - RULE-SET,BM7-Line,BM7-分流-Social

# ==================================================
# 流媒体
# ==================================================
  - RULE-SET,BM7-Netflix,BM7-分流-Streaming
  - RULE-SET,BM7-Disney,BM7-分流-Streaming
  - RULE-SET,BM7-HBO,BM7-分流-Streaming
  - RULE-SET,BM7-PrimeVideo,BM7-分流-Streaming
  - RULE-SET,BM7-Spotify,BM7-分流-Streaming
  - RULE-SET,BM7-Twitch,BM7-分流-Streaming
  - RULE-SET,BM7-Hulu,BM7-分流-Streaming
  - RULE-SET,BM7-ParamountPlus,BM7-分流-Streaming
  - RULE-SET,BM7-Emby,BM7-分流-Streaming

# ==================================================
# 游戏
# ==================================================
  - RULE-SET,BM7-SteamCN,DIRECT
  - RULE-SET,BM7-Steam,BM7-分流-Game
  - RULE-SET,BM7-Epic,BM7-分流-Game
  - RULE-SET,BM7-Nintendo,BM7-分流-Game
  - RULE-SET,BM7-Sony,BM7-分流-Game
  - RULE-SET,BM7-Xbox,BM7-分流-Game
  - RULE-SET,BM7-Game,BM7-分流-Game

# ==================================================
# Apple / Microsoft / Amazon / PayPal
# ==================================================
  - RULE-SET,BM7-Apple,BM7-分流-Apple
  - RULE-SET,BM7-Microsoft,BM7-分流-Microsoft
  - RULE-SET,BM7-Amazon,BM7-分流-Amazon
  - RULE-SET,BM7-PayPal,BM7-分流-PayPal

# ==================================================
# 国内规则
# ==================================================
  - RULE-SET,BM7-China,DIRECT
  - RULE-SET,BM7-WeChat,DIRECT
  - RULE-SET,BM7-BiliBili,DIRECT
  - RULE-SET,BM7-DouYin,DIRECT
  - RULE-SET,BM7-NetEaseMusic,DIRECT
  - RULE-SET,BM7-Baidu,DIRECT
  - RULE-SET,BM7-Alibaba,DIRECT
  - RULE-SET,BM7-Tencent,DIRECT
  - RULE-SET,BM7-ByteDance,DIRECT
  - RULE-SET,BM7-Huawei,DIRECT
  - GEOIP,CN,DIRECT


rule-providers:

  # ==================================================
  # 广告 / 隐私
  # ==================================================
  BM7-Advertising:
    type: http
    behavior: classical
    format: yaml
    url: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Advertising/Advertising.yaml
    path: ./ruleset/blackmatrix7/Advertising.yaml
    interval: 86400

  BM7-Privacy:
    type: http
    behavior: classical
    format: yaml
    url: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Privacy/Privacy.yaml
    path: ./ruleset/blackmatrix7/Privacy.yaml
    interval: 86400

  # ==================================================
  # AI
  # ==================================================
  BM7-OpenAI:
    type: http
    behavior: classical
    format: yaml
    url: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/OpenAI/OpenAI.yaml
