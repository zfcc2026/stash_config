rules:
  # 减少代理侧 QUIC/UDP 443 在弱网下的波动
  - SCRIPT,bm7_quic,REJECT

  # 钉钉 / 阿里办公直连
  - DOMAIN-SUFFIX,dingtalk.com,DIRECT
  - DOMAIN-SUFFIX,dingtalkapps.com,DIRECT
  - DOMAIN-SUFFIX,dingtalkcdn.com,DIRECT

  # 广告与隐私
  - RULE-SET,BM7-Advertising,REJECT
  - RULE-SET,BM7-Privacy,REJECT

  # AI
  - RULE-SET,BM7-OpenAI,BM7-AI
  - RULE-SET,BM7-Claude,BM7-AI
  - RULE-SET,BM7-Anthropic,BM7-AI
  - RULE-SET,BM7-Gemini,BM7-AI
  - RULE-SET,BM7-Copilot,BM7-AI

  # Developer
  - RULE-SET,BM7-GitHub,BM7-Developer
  - RULE-SET,BM7-GitLab,BM7-Developer
  - RULE-SET,BM7-Docker,BM7-Developer
  - RULE-SET,BM7-Jetbrains,BM7-Developer
  - RULE-SET,BM7-Npmjs,BM7-Developer
  - RULE-SET,BM7-Python,BM7-Developer

  # Google / YouTube / Telegram
  - RULE-SET,BM7-YouTube,BM7-YouTube
  - RULE-SET,BM7-Google,BM7-Google
  - RULE-SET,BM7-Telegram,BM7-Telegram

  # Social
  - RULE-SET,BM7-Twitter,BM7-Social
  - RULE-SET,BM7-Instagram,BM7-Social
  - RULE-SET,BM7-Facebook,BM7-Social
  - RULE-SET,BM7-Reddit,BM7-Social
  - RULE-SET,BM7-Discord,BM7-Social
  - RULE-SET,BM7-TikTok,BM7-Social
  - RULE-SET,BM7-Threads,BM7-Social
  - RULE-SET,BM7-Whatsapp,BM7-Social
  - RULE-SET,BM7-Line,BM7-Social

  # Streaming
  - RULE-SET,BM7-Netflix,BM7-Streaming
  - RULE-SET,BM7-Disney,BM7-Streaming
  - RULE-SET,BM7-HBO,BM7-Streaming
  - RULE-SET,BM7-PrimeVideo,BM7-Streaming
  - RULE-SET,BM7-Spotify,BM7-Streaming
  - RULE-SET,BM7-Twitch,BM7-Streaming
  - RULE-SET,BM7-Hulu,BM7-Streaming
  - RULE-SET,BM7-ParamountPlus,BM7-Streaming
  - RULE-SET,BM7-Emby,BM7-Streaming

  # Game
  - RULE-SET,BM7-SteamCN,DIRECT
  - RULE-SET,BM7-Steam,BM7-Game
  - RULE-SET,BM7-Epic,BM7-Game
  - RULE-SET,BM7-Nintendo,BM7-Game
  - RULE-SET,BM7-Sony,BM7-Game
  - RULE-SET,BM7-Xbox,BM7-Game
  - RULE-SET,BM7-Game,BM7-Game

  # Apple / Microsoft / Amazon / PayPal
  - RULE-SET,BM7-Apple,BM7-Apple
  - RULE-SET,BM7-Microsoft,BM7-Microsoft
  - RULE-SET,BM7-Amazon,BM7-Amazon
  - RULE-SET,BM7-PayPal,BM7-PayPal

  # 国内直连
  - RULE-SET,BM7-China,DIRECT
  - RULE-SET,BM7-WeChat,DIRECT
  - RULE-SET,BM7-BiliBili,DIRECT
  - RULE-SET,BM7-DouYin,DIRECT
  - RULE-SET,BM7-NetEaseMusic,DIRECT
  - RULE-SET,BM7-Baidu,DIRECT
  - RULE-SET,BM7-Alibaba,DIRECT
  - RULE-SET,BM7-Tencent,DIRECT
  - RULE-SET,BM7-ByteDance,DIRECT
  - RULE-SET,BM7-Huawei,DIRECT

rule-providers:
  BM7-Advertising:
    type: http
    behavior: classical
    format: yaml
    url: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/Advertising/Advertising.yaml
    path: ./ruleset/blackmatrix7/Advertising.yaml
    interval: 86400
